# ─────────────────────────────────────────────────────────────
# [Do Good] Website — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── HubSpot ──────────────────────────────────────────────────
# Found in HubSpot → Settings → Account Setup → Integrations → API Key
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Found on the form's embed code (portalId) and the form URL (formId)
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=12345678
NEXT_PUBLIC_HUBSPOT_APPLY_FORM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Stripe ───────────────────────────────────────────────────
# Publishable key — safe to expose to the client
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Secret key — server only, never expose to client
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Webhook signing secret — from Stripe Dashboard → Webhooks → endpoint
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ── Calendly ─────────────────────────────────────────────────
# Full Calendly event URL for the 20-min discovery call
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/dogood/20min

# ── Google Analytics 4 ───────────────────────────────────────
# Measurement ID from GA4 → Admin → Data Streams → Web stream
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Clerk (Auth) ─────────────────────────────────────────────
# From Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/apply
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/portal/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/portal/onboarding

# ── FundraiseUp ───────────────────────────────────────────────
# Organization ID from FundraiseUp Dashboard
NEXT_PUBLIC_FUNDRAISEUP_ORG_ID=XXXXXXXX

# ── App URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://dogoodnaas.com
